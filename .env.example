GATEWAY_APP_NAME=Gateway Backend
GATEWAY_APP_ENV=development
GATEWAY_DEBUG=true
GATEWAY_API_V1_PREFIX=/api/v1
GATEWAY_DATABASE_URL=sqlite:///./gateway.db
GATEWAY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GATEWAY_AUTH_ENABLED=false
GATEWAY_AUTH_TOKENS=admin:change-me-admin-token,operator:change-me-operator-token
GATEWAY_AUTH_SECRET_KEY=change-me-gateway-auth-secret
GATEWAY_AUTH_ACCESS_TOKEN_TTL_MINUTES=480
GATEWAY_BOOTSTRAP_ADMIN_USERNAME=admin
GATEWAY_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
GATEWAY_BOOTSTRAP_ADMIN_FULL_NAME=Gateway Administrator
GATEWAY_RATE_LIMIT_ENABLED=false
GATEWAY_RATE_LIMIT_REQUESTS=30
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_PROVIDER_TIMEOUT_SECONDS=60
GATEWAY_PROVIDER_MAX_RETRIES=1
GATEWAY_PROVIDER_RETRY_BASE_DELAY_SECONDS=1
