GATEWAY_APP_NAME=Gateway Backend
GATEWAY_APP_ENV=staging
GATEWAY_DEBUG=false
GATEWAY_API_V1_PREFIX=/api/v1
GATEWAY_DATABASE_URL=sqlite:///./gateway.db
GATEWAY_DB_FILE=./deploy/staging/gateway-staging.db
GATEWAY_CORS_ORIGINS=https://testgateway.plxeditor.com
GATEWAY_AUTH_ENABLED=true
GATEWAY_AUTH_TOKENS=admin:change-me-admin-token,operator:change-me-operator-token
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_REQUESTS=30
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_PROVIDER_TIMEOUT_SECONDS=300
GATEWAY_PROVIDER_MAX_RETRIES=2
GATEWAY_PROVIDER_RETRY_BASE_DELAY_SECONDS=1
GATEWAY_SYNC_PROVIDER_TIMEOUT_SECONDS=45
GATEWAY_SYNC_PROVIDER_MAX_RETRIES=0
GATEWAY_SYNC_FORCE_ASYNC_FUNCTIONS=text-generation,image-generation
GATEWAY_ASYNC_JOB_DEFAULT_MAX_ATTEMPTS=3
GATEWAY_ASYNC_JOB_RETRY_BASE_DELAY_SECONDS=5
GATEWAY_ASYNC_JOB_RETRY_MAX_DELAY_SECONDS=60
GATEWAY_ASYNC_JOB_BATCH_SIZE=20
GATEWAY_WEBHOOK_TIMEOUT_SECONDS=10
GATEWAY_JOB_RUNNER_INTERVAL_SECONDS=5
GATEWAY_HOST_PORT=8082
